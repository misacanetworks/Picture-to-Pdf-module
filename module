  <style>
    body { font-family: sans-serif; padding: 20px; }
    #preview { margin-top: 20px; display: flex; flex-wrap: wrap; gap: 10px; }
    #preview img { max-height: 150px; border: 1px solid #ddd; }
    #progress-container {
      margin: 20px 0;
      display: none;
      flex-direction: column;
      gap: 10px;
    }
    progress { width: 100%; height: 20px; }
    #status { font-weight: bold; }
    button:disabled { opacity: 0.6; cursor: not-allowed; }
  </style>
</head>
<body>

  <h1>書籍ページをPDF化（フロントエンドのみ）</h1>
  <p>1. 画像を選択（複数選択可）<br>2. PDF生成ボタンを押す</p>

  <input type="file" id="fileInput" multiple accept="image/*">
  <button id="generateBtn" onclick="generatePDF()">PDF生成してダウンロード</button>

  <div id="preview"></div>

  <div id="progress-container">
    <div id="status">処理中...</div>
    <progress id="progress" value="0" max="100"></progress>
    <div id="pageInfo"></div>
  </div>

  <script>
    const fileInput = document.getElementById('fileInput');
    const preview = document.getElementById('preview');
    const generateBtn = document.getElementById('generateBtn');
    const progressContainer = document.getElementById('progress-container');
    const progressBar = document.getElementById('progress');
    const statusText = document.getElementById('status');
    const pageInfo = document.getElementById('pageInfo');

    // プレビュー表示（変更なし）
    fileInput.addEventListener('change', () => {
      preview.innerHTML = '';
      Array.from(fileInput.files).forEach(file => {
        const url = URL.createObjectURL(file);
        const img = document.createElement('img');
        img.src = url;
        preview.appendChild(img);
      });
    });

    async function generatePDF() {
      const files = fileInput.files;
      if (!files.length) {
        alert('画像を選択してください');
        return;
      }

      const totalPages = files.length;

      // UIを処理中モードに
      generateBtn.disabled = true;
      progressContainer.style.display = 'flex';
      progressBar.value = 0;
      statusText.textContent = '処理を開始します...';
      pageInfo.textContent = `0 / ${totalPages} ページ`;

      // デフォルトファイル名
      const now = new Date();
      const y = now.getFullYear(), m = String(now.getMonth()+1).padStart(2,'0');
      const d = String(now.getDate()).padStart(2,'0');
      const h = String(now.getHours()).padStart(2,'0');
      const min = String(now.getMinutes()).padStart(2,'0');
      const defaultName = `mini-app-pdf-${y}-${m}-${d}-${h}-${min}.pdf`;

      const fileName = prompt('保存ファイル名（.pdfは自動）', defaultName) || defaultName;
      const finalName = fileName.endsWith('.pdf') ? fileName : `${fileName}.pdf`;

      const { jsPDF } = window.jspdf;
      let doc;

      for (let i = 0; i < totalPages; i++) {
        const file = files[i];
        statusText.textContent = `処理中: ${i+1} / ${totalPages} ページ`;
        pageInfo.textContent = `${i} / ${totalPages} ページ完了`;

        // 進捗を更新（0〜100%）
        progressBar.value = Math.round((i / totalPages) * 100);

        // 画像をData URLに変換
        const dataUrl = await new Promise(resolve => {
          const reader = new FileReader();
          reader.onload = e => resolve(e.target.result);
          reader.readAsDataURL(file);
        });

        // 画像サイズ取得
        const img = new Image();
        await new Promise(resolve => {
          img.onload = resolve;
          img.src = dataUrl;
        });

        const isLandscape = img.width > img.height;
        const orientation = isLandscape ? 'l' : 'p';

        if (i === 0) {
          doc = new jsPDF({ orientation, unit: 'mm', format: 'a4' });
        } else {
          doc.addPage(orientation);
        }

        const pageWidth = doc.internal.pageSize.getWidth();
        const pageHeight = doc.internal.pageSize.getHeight();
        const margin = 5;
        const availableWidth = pageWidth - margin * 2;
        const availableHeight = pageHeight - margin * 2;
        const ratio = Math.min(availableWidth / img.width, availableHeight / img.height);
        const imgW = img.width * ratio;
        const imgH = img.height * ratio;
        const x = (pageWidth - imgW) / 2;
        const y = (pageHeight - imgH) / 2;

        doc.addImage(dataUrl, 'JPEG', x, y, imgW, imgH);
      }

      // 最終進捗100%
      progressBar.value = 100;
      statusText.textContent = 'PDF生成完了！保存中...';
      pageInfo.textContent = `${totalPages} / ${totalPages} ページ`;

      doc.save(finalName);

      // UIを元に戻す
      setTimeout(() => {
        generateBtn.disabled = false;
        progressContainer.style.display = 'none';
        alert(`PDF生成完了！\nファイル名：${finalName}`);
      }, 500);
    }
  </script>

</body>
</html>
