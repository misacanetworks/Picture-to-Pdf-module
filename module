<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>画像をPDF化（書籍ページ用）</title>
  <script src="https://unpkg.com/jspdf@latest/dist/jspdf.umd.min.js"></script>

  <!-- 
